{
  "name": "portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NEXT_DIST_DIR=.next-dev __NEXT_DEVTOOL_SEGMENT_EXPLORER=false next dev",
    "dev:fresh": "node -e \"require('fs').rmSync('.next-dev',{recursive:true,force:true})\" && cross-env NEXT_DIST_DIR=.next-dev __NEXT_DEVTOOL_SEGMENT_EXPLORER=false next dev",
    "build": "cross-env NEXT_DIST_DIR=.next-build next build",
    "lint": "eslint .",
    "start": "cross-env NEXT_DIST_DIR=.next-build next start"
  },
  "dependencies": {
    "framer-motion": "^12.35.2",
    "lucide-react": "^0.511.0",
    "next": "^15.3.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-draggable": "^4.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.8.3"
  }
}
